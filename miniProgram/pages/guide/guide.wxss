.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f3e8ff 0%, #f5f7fa 28%, #eef2f7 100%);
}

.hero {
  padding: 36rpx 28rpx 40rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, #6750a4 0%, #7c4dff 100%);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(103, 80, 164, 0.35);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.65;
}

.section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(103, 80, 164, 0.08);
}

.section-tip {
  background: rgba(103, 80, 164, 0.06);
  border-color: rgba(103, 80, 164, 0.12);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-icon {
  font-size: 36rpx;
  line-height: 1;
}

.block-h {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #6750a4;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
}

.block-h:first-child {
  margin-top: 0;
}

.block-p {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.75;
  margin-bottom: 16rpx;
}

.block-p:last-child {
  margin-bottom: 0;
}

.footer-space {
  height: 24rpx;
}
